<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="PrimaryBackgroundColor">#1E1E1E</Color>
    <Color x:Key="SecondaryBackgroundColor">#252526</Color>
    <Color x:Key="CardBackgroundColor">#2D2D30</Color>
    <Color x:Key="HeaderBackgroundColor">#0078D4</Color>
    <Color x:Key="NavButtonActiveBackgroundColor">#073042</Color>
    <Color x:Key="DisabledBackgroundColor">#3A3A3A</Color>
    <Color x:Key="SubtleBackgroundPressedColor">#383838</Color>
    <Color x:Key="StatusInfoBackgroundColor">#2A2A2A</Color>

    <Color x:Key="PrimaryTextColor">#FFFFFF</Color>
    <Color x:Key="SecondaryTextColor">#C8C8C8</Color>
    <Color x:Key="InvertedTextColor">#000000</Color>
    <Color x:Key="AccentTextColor">#A9D6FF</Color>
    <Color x:Key="DisabledForegroundColor">#999999</Color>

    <Color x:Key="PrimaryBorderColor">#3F3F46</Color>
    <Color x:Key="SecondaryBorderColor">#444444</Color>

    <Color x:Key="AccentColor">#0078D4</Color>
    <Color x:Key="AccentMouseOverColor">#106EBE</Color>
    <Color x:Key="AccentPressedColor">#005A9E</Color>

    <Color x:Key="DangerColor">#D13438</Color>
    <Color x:Key="DangerMouseOverColor">#B02E31</Color>
    <Color x:Key="DangerPressedColor">#A2262A</Color>

    <Color x:Key="SuccessColor">#107C10</Color>
    <Color x:Key="WarningColor">#FFCC00</Color>
    <Color x:Key="InfoColor">#6BB6FF</Color>

    <SolidColorBrush x:Key="PrimaryBackgroundBrush" Color="{StaticResource PrimaryBackgroundColor}"/>
    <SolidColorBrush x:Key="SecondaryBackgroundBrush" Color="{StaticResource SecondaryBackgroundColor}"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackgroundColor}"/>
    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="{StaticResource HeaderBackgroundColor}"/>
    <SolidColorBrush x:Key="NavButtonActiveBackgroundBrush" Color="{StaticResource NavButtonActiveBackgroundColor}"/>
    <SolidColorBrush x:Key="DisabledBackgroundBrush" Color="{StaticResource DisabledBackgroundColor}"/>
    <SolidColorBrush x:Key="SubtleBackgroundPressedBrush" Color="{StaticResource SubtleBackgroundPressedColor}"/>
    <SolidColorBrush x:Key="StatusInfoBackgroundBrush" Color="{StaticResource StatusInfoBackgroundColor}"/>

    <SolidColorBrush x:Key="PrimaryTextBrush" Color="{StaticResource PrimaryTextColor}"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource SecondaryTextColor}"/>
    <SolidColorBrush x:Key="InvertedTextBrush" Color="{StaticResource InvertedTextColor}"/>
    <SolidColorBrush x:Key="AccentTextBrush" Color="{StaticResource AccentTextColor}"/>
    <SolidColorBrush x:Key="DisabledForegroundBrush" Color="{StaticResource DisabledForegroundColor}"/>

    <SolidColorBrush x:Key="PrimaryBorderBrush" Color="{StaticResource PrimaryBorderColor}"/>
    <SolidColorBrush x:Key="SecondaryBorderBrush" Color="{StaticResource SecondaryBorderColor}"/>

    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentMouseOverBrush" Color="{StaticResource AccentMouseOverColor}"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="{StaticResource AccentPressedColor}"/>

    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="DangerMouseOverBrush" Color="{StaticResource DangerMouseOverColor}"/>
    <SolidColorBrush x:Key="DangerPressedBrush" Color="{StaticResource DangerPressedColor}"/>

    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}"/>

</ResourceDictionary>